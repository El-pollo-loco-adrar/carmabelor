---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import photoSalon from '../assets/institut/inst1.jpg';
import photoSalon2 from '../assets/institut/inst2.jpg';
import photoSalon3 from '../assets/institut/inst3.jpeg';
import photoSalon4 from '../assets/institut/inst4.jpeg';
import patron from '../assets/patron.jpg';
import logoGalland from '../assets/mariagalland-logo2.png';
import logoLpg from '../assets/lpg-logo.jpg';
---
<style>
    /* Empêche le saut de page brutal lors du clic sur les ancres du carousel */
    .carousel-item {
        /* Ajuste cette valeur selon la hauteur de ta Navbar (ex: 100px) */
        scroll-margin-top: 150px; 
    }

    /* Optionnel : adoucir le mouvement */
    html {
        scroll-behavior: smooth;
    }
</style>
<Layout 
    title="L'institut Carmabelor à Toulouse"
    description="Découvrez l'institut Elégance Carmabelor à Toulouse, son histoire et ses valeurs."
>
    <!-- LIEN PETIT TOU -->
    <section class="py-20 max-w-7xl mx-auto px-4">
        <div class="text-center relative z-10">
            <h1 class="text-4xl md:text-5xl font-serif text-primary italic mb-4">L'institut Élégance Carmabelor</h1>
        </div>
    </section>

    <section class="max-w-4xl mx-auto px-4 -mt-12 relative z-20 mb-16">
    </section>

    <!-- CAROUSEL -->
    <section class="max-w-6xl mx-auto px-2 md:px-4 mb-16">
    <div class="carousel w-full shadow-2xl rounded-3xl overflow-hidden border-4 md:border-8 border-white">
        <div id="slide1" class="carousel-item relative w-full h-[400px] md:h-[600px]">
            <Image 
                src={photoSalon3}
                alt="L'intérieur chaleureux de l'institut Carmabelor"
                width={1200} 
                height={600}
                class="w-full h-full object-cover"
                loading="eager" 
            />
            <div class="absolute left-5 right-5 top-1/2 flex -translate-y-1/2 transform justify-between">
                <a href="#slide4" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white hover:bg-white/50" aria-label="Afficher la photo précédente">❮</a>
                <a href="#slide2" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white hover:bg-white/50" aria-label="Afficher la photo suivante">❯</a>
            </div>
        </div>
        
        <div id="slide2" class="carousel-item relative w-full h-[400px] md:h-[600px]">
            <Image src={photoSalon2} alt="..." width={1200} height={600} class="w-full h-full object-cover" />
            <div class="absolute left-5 right-5 top-1/2 flex -translate-y-1/2 transform justify-between">
                <a href="#slide1" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white" aria-label="Afficher la photo précédente">❮</a>
                <a href="#slide3" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white" aria-label="Afficher la photo suivante">❯</a>
            </div>
        </div>

        <div id="slide3" class="carousel-item relative w-full h-[400px] md:h-[600px]">
            <Image src={photoSalon} alt="..." width={1200} height={600} class="w-full h-full object-cover" />
            <div class="absolute left-5 right-5 top-1/2 flex -translate-y-1/2 transform justify-between">
                <a href="#slide2" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white" aria-label="Afficher la photo précédente">❮</a>
                <a href="#slide4" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white" aria-label="Afficher la photo suivante">❯</a>
            </div>
        </div>

        <div id="slide4" class="carousel-item relative w-full h-[400px] md:h-[600px]">
            <Image src={photoSalon4} alt="..." width={1200} height={600} class="w-full h-full object-cover" />
            <div class="absolute left-5 right-5 top-1/2 flex -translate-y-1/2 transform justify-between">
                <a href="#slide3" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white" aria-label="Afficher la photo précédente">❮</a>
                <a href="#slide1" class="btn btn-circle btn-ghost bg-white/30 backdrop-blur-md border-none text-white" aria-label="Afficher la photo suivante">❯</a>
            </div>
        </div>
    </div>

    <div class="flex w-full justify-center gap-2 py-4">
        <a href="#slide1" class="btn btn-xs btn-circle btn-primary btn-outline opacity-50 hover:opacity-100" aria-label="Afficher la photo 1 sur 4"></a>
        <a href="#slide2" class="btn btn-xs btn-circle btn-primary btn-outline opacity-50 hover:opacity-100" aria-label="Afficher la photo 2 sur 4"></a>
        <a href="#slide3" class="btn btn-xs btn-circle btn-primary btn-outline opacity-50 hover:opacity-100" aria-label="Afficher la photo 3 sur 4"></a>
        <a href="#slide4" class="btn btn-xs btn-circle btn-primary btn-outline opacity-50 hover:opacity-100" aria-label="Afficher la photo 4 sur 4"></a>
    </div>
    </section>

    <!-- MOT GERANTE -->
