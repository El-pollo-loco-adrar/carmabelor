    <!-- MARQUES PARTENAIRES -->
    <section class="py-20 bg-base-200">
        <div class="max-w-6xl mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-serif italic text-primary">L'Excellence à votre service</h2>
                <div class="w-24 h-[1px] bg-primary/20 mx-auto mt-4"></div>
                <p class="max-w-2xl mx-auto mt-6 text-neutral/70 leading-relaxed font-light">
                    Parce que votre peau mérite le meilleur, nous avons sélectionné des partenaires de renommée internationale, leaders de la haute cosmétique et de la technologie esthétique.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center justify-items-center opacity-80">
                
                <div class="group flex flex-col items-center space-y-4">
                    <div class="h-24 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all duration-500">
                        <Image 
                            src={logoGalland}
                            alt="Logo Maria Galland Paris - Soins cosmétiques haute performance"
                            width={500}
                            height={500}
                            class="w-full h-full object-cover"
                            loading="lazy" 
                        />
                    </div>
                    <p class="text-center text-xs tracking-widest uppercase opacity-60 max-w-[250px]">
                        L'icône de la cosmétique française pour des soins sur-mesure.
                    </p>
                </div>

                <div class="group flex flex-col items-center space-y-4">
                    <div class="px-4 py-1 border border-primary/30 rounded-full bg-primary/5">
                        <span class="text-[10px] uppercase tracking-widest font-bold text-primary italic">Centre Expert Agréé</span>
                    </div>
                    <div class="h-24 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all duration-500">
                        <Image 
                            src={logoLpg}
                            alt="Logo LPG Endermologie"
                            width={500}
                            height={500}
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <p class="text-center text-xs tracking-widest uppercase opacity-60 max-w-[250px]">
                        Équipé de la nouvelle technologie <strong>LPG Cellu M6 Infinity</strong>.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <!-- CITATION DU PETIT TOU -->
    <section class="max-w-3xl mx-auto px-6 py-16 text-center">
        <div class="space-y-6">
            <div class="flex justify-center items-center gap-3">
                <span class="h-[1px] w-6 bg-primary/20"></span>
                <a href="https://www.lepetittou.com/le-petit-tou/etablissement/elegance-institut-carmabelor/" target="_blank" rel="noopener noreferrer" class="text-[10px] md:text-xs uppercase tracking-[0.3em] text-neutral/50 hover:text-primary transition-all duration-300 group" aria-label="Lire l'article sur Le Petit Tou (ouvre un nouvel onglet)">
                    Vu dans <span class="font-bold">Le Petit Tou</span> City Guide
                    <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
                </a>
                <span class="h-[1px] w-6 bg-primary/20"></span>
            </div>
            <div class="flex justify-center gap-1 text-primary/40">
                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            </div>
            <blockquote class="text-xl md:text-2xl font-serif italic text-neutral leading-relaxed">
                "Un véritable moment d’évasion où expertise et raffinement se rencontrent. L’accueil chaleureux de Jessica transforme votre visite en un moment unique de bien-être absolu."
            </blockquote>
            <div class="flex flex-col items-center">
                <span class="text-[10px] uppercase tracking-widest font-bold text-primary/70">Le Petit Tou</span>
                <span class="text-[9px] uppercase tracking-[0.2em] text-neutral/40">City Guide Toulouse</span>
            </div>
        </div>
    </section>

    <!-- POURQUOI CHOISIR -->
    <section class="bg-base-200 py-20">
    <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-serif italic">Pourquoi nous choisir ?</h2>
        </div>
        
        <div class="grid md:grid-cols-3 gap-12">
            <div class="text-center space-y-4">
                <div class="text-4xl">🌿</div>
                <h3 class="text-xl font-bold uppercase tracking-widest text-primary">Expertise Maria Galland</h3>
                <p class="text-sm opacity-70">Des protocoles sur-mesure utilisant les produits iconiques de la marque numéro 1 en institut.</p>
            </div>

            <div class="relative text-center space-y-4 p-6 bg-white/50 rounded-2xl border border-primary/10 shadow-sm md:-translate-y-4">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-white text-[9px] font-bold uppercase tracking-[0.2em] px-3 py-1 rounded-full shadow-md">
                    Pionnier à Toulouse
                </div>
                
                <div class="text-4xl pt-2">💎</div>
                <h3 class="text-xl font-bold uppercase tracking-widest text-primary">Centre Expert LPG</h3>
                <p class="text-sm opacity-80 leading-relaxed">
                    <strong>Premier institut à Toulouse</strong> équipé de la nouvelle technologie <strong>Infinity</strong>. Une expertise unique pour des résultats minceur et anti-âge inégalés.
                </p>
                <div class="text-[10px] uppercase tracking-widest text-primary/60 font-semibold italic">Technologie Cellu M6 Infinity</div>
            </div>

            <div class="text-center space-y-4">
                <div class="text-4xl">✨</div>
                <h3 class="text-xl font-bold uppercase tracking-widest text-primary">Cadre Privilégié</h3>
                <p class="text-sm opacity-70">Un espace intimiste et apaisant conçu pour votre confort et votre tranquillité.</p>
            </div>
        </div>
    </div>
    </section>

    <!-- Les avis -->
    <section class="py-20 ">
    <div class="max-w-6xl mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
            <div>
                <h2 class="text-3xl font-serif italic text-primary">Ce que disent nos clientes</h2>
                <div class="flex items-center gap-2 mt-2">
                    <div class="flex text-orange-400">
                        <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                    </div>
                    <span class="text-sm font-bold">5/5 sur Google</span>
                </div>
            </div>
            <a href="https://www.google.com/search?q=Elegance+Institut+Carmabelor+avis" target="_blank" class="btn btn-outline btn-primary btn-sm rounded-full">
                Voir tous les avis
            </a>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <div class="bg-base-200 p-8 rounded-3xl relative">
                <span class="text-6xl absolute top-4 right-8 opacity-10 font-serif">"</span>
                <div class="flex text-orange-400 mb-4 text-xs">
                    ★ ★ ★ ★ ★
                </div>
                <p class="text-sm italic leading-relaxed mb-6 opacity-80">
                    "Je recommande cet institut les yeux fermés!Jessica est d’un grand professionnalisme, elle s’est montrée disponible et soucieuse de répondre à mes besoins. Soins et produits d’excellente qualité,je n’ai jamais été déçue !"
                </p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center font-bold text-primary text-xs">ML</div>
                    <span class="font-bold text-xs uppercase tracking-widest">charlotte b</span>
                </div>
            </div>

            <div class="bg-base-200 p-8 rounded-3xl relative">
                <span class="text-6xl absolute top-4 right-8 opacity-10 font-serif">"</span>
                <div class="flex text-orange-400 mb-4 text-xs">
                    ★ ★ ★ ★ ★
                </div>
                <p class="text-sm italic leading-relaxed mb-6 opacity-80">
                    "Jessica propose des soins très qualitatifs notamment le denier LPG. J’ai fait des séances dans un autre institut mais je vois la différence et celui est lié à la technique utilisée. Je recommande sincèrement"
                </p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center font-bold text-primary text-xs">SC</div>
                    <span class="font-bold text-xs uppercase tracking-widest">Anna Dom M.</span>
                </div>
            </div>

            <div class="bg-base-200 p-8 rounded-3xl relative">
                <span class="text-6xl absolute top-4 right-8 opacity-10 font-serif">"</span>
                <div class="flex text-orange-400 mb-4 text-xs">
                    ★ ★ ★ ★ ★
                </div>
                <p class="text-sm italic leading-relaxed mb-6 opacity-80">
                    "Un moment de pure détente ! J’ai effectué un soin du visage et un massage du corps, et ce fut une expérience incroyable. Jessica est douce et très professionnelle. Je recommande sans hésitation !"
                </p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center font-bold text-primary text-xs">JD</div>
                    <span class="font-bold text-xs uppercase tracking-widest">Maylis Dupeyrat-Delrieu</span>
                </div>
            </div>
        </div>
    </div>
</section>
</Layout>