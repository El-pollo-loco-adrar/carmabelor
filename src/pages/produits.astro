---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import gammes from "../data/produits.json";

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/produits/*.{jpeg,jpg,png,gif,webp}');

interface Gamme {
    id: string;
    title: string;
    image: string;
    brand: string;
    description: string;
}

const productGammes = (gammes as Gamme[]);
---

<Layout title="Nos Gammes Maria Galland | Institut Carmabelor" description="Découvrez l'univers des soins Maria Galland Paris disponibles dans votre institut à Toulouse.">
    
    <section class="py-20 max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-serif text-primary italic mb-4">Le Comptoir Beauté</h1>
            <p class="mt-4 text-neutral/70 uppercase tracking-widest text-xs">L'expertise Maria Galland Paris dans votre routine quotidienne</p>
        </div>

        <div class="flex flex-wrap justify-center gap-4 md:gap-6">
    {productGammes.map((gamme) => (
        <label 
            for={`modal-${gamme.id}`} 
            // 
            class="group cursor-pointer relative overflow-hidden rounded-2xl aspect-[4/5] shadow-md border border-base-200 focus-within:ring-2 focus-within:ring-primary focus-within:ring-offset-2 outline-none w-[46%] lg:w-[22%] max-w-[260px]"
            role="button"
            tabindex="0"
        >
            {images[`/src/assets/produits/${gamme.image}`] && (
                <Image 
                    src={images[`/src/assets/produits/${gamme.image}`]()} 
                    alt={gamme.title}
                    width={400}
                    height={500}
                    class="object-cover w-full h-full transition-transform duration-1000 group-hover:scale-110"
                />
            )}
            
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-opacity group-hover:opacity-90"></div>
            
            <div class="absolute inset-0 flex flex-col items-center justify-end text-white p-4 md:p-6 text-center translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                <span class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] opacity-80 mb-1">{gamme.brand}</span>
                <h2 class="text-lg md:text-xl font-serif italic mb-3">{gamme.title}</h2>
                <div class="w-8 h-[1px] bg-white/50 mb-3"></div>
                <span class="text-[9px] uppercase tracking-widest font-bold border border-white/30 px-3 py-1.5 rounded-full hover:bg-white hover:text-black transition-colors">
                    Détails
                </span>
            </div>
        </label>
    ))}
</div>
