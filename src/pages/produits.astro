    </section>

    {productGammes.map((gamme) => (
        <>
            <input type="checkbox" id={`modal-${gamme.id}`} class="modal-toggle" />
            <div class="modal modal-bottom sm:modal-middle px-4" role="dialog">
                <div class="modal-box max-w-2xl bg-white p-0 overflow-hidden rounded-3xl">
                    
                    <div class="p-8 md:p-12 text-center space-y-6">
                        <div class="flex flex-col items-center gap-2">
                            <span class="text-[10px] uppercase tracking-[0.4em] text-primary font-bold">{gamme.brand}</span>
                            <h3 class="text-3xl md:text-4xl font-serif italic text-neutral">{gamme.title}</h3>
                            <div class="w-16 h-[1px] bg-primary/20 mt-2"></div>
                        </div>
                        
                        <p class="text-neutral/70 leading-relaxed text-lg font-light italic">
                            {gamme.description}
                        </p>

                        <div class="pt-6">
                            <p class="text-[10px] uppercase tracking-widest text-neutral/40 mb-6">
                                Conseils personnalisés et vente à l'institut
                            </p>
                            <label for={`modal-${gamme.id}`} class="btn btn-primary btn-outline rounded-full px-12 hover:bg-primary hover:text-white transition-all">
                                Fermer
                            </label>
                        </div>
                    </div>

                </div>
                <label class="modal-backdrop" for={`modal-${gamme.id}`}>Close</label>
            </div>
        </>
    ))}
</Layout>